node("agent-01"){
    def javaJdk = tool name: 'JDK-11', type: 'jdk'
    def maven = tool name: 'maven-3-5-4', type: 'maven'
    env.PATH = "${javaJdk}/bin:${maven}/bin:${env.PATH}"

    stage("Checkout SCM"){
        git branch: 'main', url: 'https://github.com/Hassan-Eid-Hassan/git-depi.git'
    }
    stage("Build Application") {
            echo "${javaJdk}"
            echo "${maven}"
            echo "${env.PATH}"
            sh "mvn package install -DskipTests"
    }
    stage("Test Application") {
            sh "mvn test"
    }
    stage("Build Docker Image") {
            sh "docker build -t hassaneid/depi-java:v${BUILD_NUMBER} ."
    }
    stage("Push Image") {
        withCredentials([string(credentialsId: 'docker-username', variable: 'DOCKER_USERNAME'), string(credentialsId: 'docker-password', variable: 'DOCKER_PASSWORD')]) {
             sh "docker login -u ${DOCKER_USERNAME} -p ${DOCKER_PASSWORD}"
        }
        sh "docker push hassaneid/depi-java:v${BUILD_NUMBER}"
    }
}